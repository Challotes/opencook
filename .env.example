# Required for agent chat
ANTHROPIC_API_KEY=sk-ant-...

# Global daily request cap for the "Ask AI" route (/api/agent) — cost circuit-breaker.
# Bounds total Anthropic spend across ALL callers (the per-IP limit is bypassable
# behind shared NAT / many IPs / a viral spike). When the day's total exceeds this,
# the route stops calling Anthropic until UTC midnight. Optional — defaults to 2000.
# In-memory backstop; pair with a monthly spend limit set in the Anthropic console.
AGENT_DAILY_LIMIT=2000

# BSV server wallet for on-chain posting (OP_RETURN)
# Generate with: node scripts/generate-wallet.mjs
# Fund the address with ~10,000 sats (~$0.005) for thousands of posts
# If not set, posts are saved to DB only (no on-chain logging)
BSV_SERVER_WIF=

# Database path (defaults to ./local.db if not set)
# For Railway: /data/local.db
DATABASE_PATH=

# Port (Railway sets this automatically)
PORT=3000
