# Required for agent chat
ANTHROPIC_API_KEY=sk-ant-...

# Global daily request cap for the "Ask AI" route (/api/agent) — cost circuit-breaker.
# Bounds total Anthropic spend across ALL callers (the per-IP limit is bypassable
# behind shared NAT / many IPs / a viral spike). When the day's total exceeds this,
# the route stops calling Anthropic until UTC midnight. Optional — defaults to 2000.
# In-memory backstop; pair with a monthly spend limit set in the Anthropic console.
AGENT_DAILY_LIMIT=2000

# Voice-to-text (the compose-box mic). The browser records audio and POSTs it to
# /api/transcribe, which forwards to Groq's OpenAI-compatible Whisper API. Free
# key (no card) from https://console.groq.com/keys — free tier is 2,000
# transcriptions/day, then ~$0.04/hour of audio. If UNSET, the mic shows "voice
# input is offline" on tap; everything else works. (This replaced the Web Speech
# API, which is unfixable on iOS home-screen PWAs.)
GROQ_API_KEY=

# Global daily cap on transcription requests (/api/transcribe) — cost circuit-
# breaker across ALL callers, like AGENT_DAILY_LIMIT. Optional, defaults to 2000
# (= Groq's free daily tier). In-memory; resets on restart + UTC midnight.
TRANSCRIBE_DAILY_LIMIT=

# BSV server wallet for on-chain posting (OP_RETURN)
# Generate with: node scripts/generate-wallet.mjs
# Fund the address with ~10,000 sats (~$0.005) for thousands of posts
# If not set, posts are saved to DB only (no on-chain logging)
BSV_SERVER_WIF=

# Kill-switch (Phase 2 Build C): set to "true" or "1" to DISABLE all server-wallet
# spending in an emergency (e.g. the wallet is being drained or the WIF leaked).
# When disabled: free boots transparently route to PAID (client-funded — the user
# pays, no free-boot grant is consumed) and NEW posts are REFUSED (Phase 4: refused
# up front, never stored off-chain — not silently skipped). Paid boots are
# UNAFFECTED (they spend the user's own funds, not the server wallet).
# Env var = takes effect on redeploy; default (unset) = spending enabled.
BSV_WALLET_SPEND_DISABLED=

# Phase 4 abuse/cost caps (all optional — sane defaults).
# Daily server-wallet spend ceiling in sats, across post on-chain logging AND
# free-boost payouts (shared wallet). Default ~1,721,170 (~$0.20/day at ~$11.62/BSV
# = ~26k posts or ~1.4k free boosts/day). In-memory: resets on restart + UTC
# midnight. The aggregate backstop behind the per-IP caps.
SERVER_DAILY_SPEND_SATS=

# Per-IP daily cap on server-funded on-chain post logging. Over the cap a post is
# REFUSED (never stored off-chain), surfaced as "Daily post limit reached".
# Default 200 — sized to only ever bite genuine abuse (no human posts 200x/day),
# high enough that shared/CGNAT IPs aren't hit at launch scale. REQUIRES a trusted
# proxy to set x-forwarded-for / x-real-ip (see Deployment Notes) — without one,
# header-less requests share one bucket and fail toward REFUSED.
ONCHAIN_POST_IP_LIMIT=

# Phase 5 observability. Optional bearer token gating GET /api/health (the
# operational snapshot — wallet balance, pending-anchor count, daily spend,
# kill-switch state; returns 503 when a critical condition trips so an uptime
# monitor can email on non-200). UNSET = open (still cached 10s + rate-limited).
# SET in production, then point a free uptime monitor at /api/health?token=...
# alerting on non-200 / ok:false. The endpoint never exposes the WIF or address.
HEALTH_TOKEN=

# Pre-publish content denylist (Phase 3, illegal-floor only). Posts matching any
# pattern are rejected BEFORE they reach the DB or the chain — the one point that
# can stop content reaching the immutable ledger. ONE pattern per line (commas also
# separate); a line wrapped in /slashes/ is a case-insensitive regex, otherwise it's
# a case-insensitive substring; blank lines and lines starting with # are ignored.
# Scope to ILLEGAL content only, not opinions (free-speech ethos). Deliberately NOT
# committed (no slur dump in a public repo). UNSET = no filtering (permissive) — you
# MUST set this before a public launch. NOTE: best-effort + extensible, not a
# comprehensive filter (text denylists can't catch coded/novel content).
CONTENT_DENYLIST=

# Database path (defaults to ./local.db if not set)
# For Railway: /data/local.db
DATABASE_PATH=

# Port (Railway sets this automatically)
PORT=3000
