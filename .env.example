# Required for agent chat
ANTHROPIC_API_KEY=sk-ant-...

# BSV server wallet for on-chain posting (OP_RETURN)
# Generate with: node scripts/generate-wallet.mjs
# Fund the address with ~10,000 sats (~$0.005) for thousands of posts
# If not set, posts are saved to DB only (no on-chain logging)
BSV_SERVER_WIF=

# Database path (defaults to ./local.db if not set)
# For Railway: /data/local.db
DATABASE_PATH=

# Port (Railway sets this automatically)
PORT=3000

# E30 stale-key session-lockout feature flag (optional, defaults to OFF)
# When set to the literal string "true", /api/posts returns a `key_status: { stale: true }`
# signal to the client when the polling pubkey has a forward migration on-chain. The
# client then auto-opens the StaleKeyModal and replaces PostForm's textarea with an
# amber banner — blocking compose flow until the user restores their newer recovery
# file. When unset or any other value, the feature is dark (server omits the field,
# client treats absence as not-stale via fail-open).
#
# Why a flag: E30 is the only feature that introduces visible UI state changes from
# a server signal. If the detection misfires (server bug, edge case), this flag is
# the kill switch — flip to false, behavior reverts in seconds, no redeploy needed.
# Other identity security checks (E29 block-restore, E31 block-rotate) are pure
# server-side gates with no UI implications, so they're always on.
#
# Strict string match — "true" enables, anything else (including "TRUE", "1") is off.
# See DECISIONS.md "E30 stale-key session-lockout" for full context.
E30_STALE_KEY_ENABLED=
